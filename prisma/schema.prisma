// darceflow — Prisma schema
// Phase 1 scope: tenant (Gym) + identity (User + Auth.js v5 adapter tables).
// Domain models (classes, attendance, techniques, billing) land in later phases.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7 requirement).
  // Runtime client uses the Neon driver adapter wired in lib/db.ts.
}

enum Role {
  ADMIN
  COACH
  STUDENT
}

enum BeltRank {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
}

model Gym {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  classDefinitions ClassDefinition[]
  classSessions    ClassSession[]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(STUDENT)
  belt           BeltRank?
  stripes        Int       @default(0)
  gymId          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  gym             Gym?              @relation(fields: [gymId], references: [id])
  accounts        Account[]
  sessions        Session[]
  coachedClasses  ClassDefinition[] @relation("CoachClasses")

  @@index([gymId])
}

// --- Domain models (Phase 3+) ----------------------------------------------

model ClassDefinition {
  id          String   @id @default(cuid())
  gymId       String
  name        String
  description String?
  // 0 = Sunday, 6 = Saturday
  dayOfWeek   Int
  // "HH:MM" 24h local-time string. Avoids TZ ambiguity for recurring classes.
  startTime   String
  durationMin Int
  capacity    Int      @default(20)
  coachId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym      Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  coach    User?          @relation("CoachClasses", fields: [coachId], references: [id], onDelete: SetNull)
  sessions ClassSession[]

  @@index([gymId])
  @@index([coachId])
}

model ClassSession {
  id                String   @id @default(cuid())
  classDefinitionId String
  gymId             String
  scheduledAt       DateTime
  createdAt         DateTime @default(now())

  classDefinition ClassDefinition @relation(fields: [classDefinitionId], references: [id], onDelete: Cascade)
  gym             Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, scheduledAt])
  @@index([classDefinitionId, scheduledAt])
}

// --- Auth.js v5 (@auth/prisma-adapter) required tables ----------------------
// Field names match the adapter spec exactly — do not rename.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
