// darceflow — Prisma schema
// Phase 1 scope: tenant (Gym) + identity (User + Auth.js v5 adapter tables).
// Domain models (classes, attendance, techniques, billing) land in later phases.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7 requirement).
  // Runtime client uses the Neon driver adapter wired in lib/db.ts.
}

enum Role {
  ADMIN
  COACH
  STUDENT
}

enum BeltRank {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
}

enum BodyPart {
  HEAD
  NECK
  SHOULDER
  ELBOW
  WRIST
  HAND_FINGER
  RIBS
  BACK
  HIP
  GROIN
  KNEE
  ANKLE
  FOOT_TOE
  OTHER
}

enum InjurySeverity {
  MINOR
  MODERATE
  SEVERE
}

enum InjuryStatus {
  ACTIVE
  RECOVERING
  RESOLVED
}

enum CompetitionPlacement {
  GOLD
  SILVER
  BRONZE
  FOURTH
  DNP
}

model Gym {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  classDefinitions   ClassDefinition[]
  classSessions      ClassSession[]
  beltPromotions     BeltPromotion[]
  competitionResults CompetitionResult[]
  injuries           Injury[]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(STUDENT)
  belt           BeltRank?
  stripes        Int       @default(0)
  weightClassKg  Int?
  bio            String?
  gymId          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  gym                Gym?                @relation(fields: [gymId], references: [id])
  accounts           Account[]
  sessions           Session[]
  coachedClasses     ClassDefinition[]   @relation("CoachClasses")
  promotionsReceived BeltPromotion[]     @relation("PromotionsReceived")
  promotionsAwarded  BeltPromotion[]     @relation("PromotionsAwarded")
  competitionResults CompetitionResult[]
  injuries           Injury[]

  @@index([gymId])
}

// --- Domain models (Phase 3+) ----------------------------------------------

model ClassDefinition {
  id          String   @id @default(cuid())
  gymId       String
  name        String
  description String?
  // 0 = Sunday, 6 = Saturday
  dayOfWeek   Int
  // "HH:MM" 24h local-time string. Avoids TZ ambiguity for recurring classes.
  startTime   String
  durationMin Int
  capacity    Int      @default(20)
  coachId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym      Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  coach    User?          @relation("CoachClasses", fields: [coachId], references: [id], onDelete: SetNull)
  sessions ClassSession[]

  @@index([gymId])
  @@index([coachId])
}

model ClassSession {
  id                String   @id @default(cuid())
  classDefinitionId String
  gymId             String
  scheduledAt       DateTime
  createdAt         DateTime @default(now())

  classDefinition ClassDefinition @relation(fields: [classDefinitionId], references: [id], onDelete: Cascade)
  gym             Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, scheduledAt])
  @@index([classDefinitionId, scheduledAt])
}

// --- Athlete history (Phase 4) ---------------------------------------------

model BeltPromotion {
  id           String    @id @default(cuid())
  userId       String
  gymId        String
  fromBelt     BeltRank?
  fromStripes  Int       @default(0)
  toBelt       BeltRank
  toStripes    Int       @default(0)
  awardedById  String?
  awardedAt    DateTime  @default(now())
  note         String?

  user      User @relation("PromotionsReceived", fields: [userId], references: [id], onDelete: Cascade)
  awardedBy User? @relation("PromotionsAwarded", fields: [awardedById], references: [id], onDelete: SetNull)
  gym       Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([userId, awardedAt])
  @@index([gymId, awardedAt])
}

model CompetitionResult {
  id            String                @id @default(cuid())
  userId        String
  gymId         String
  eventName     String
  division      String?
  weightClassKg Int?
  placement     CompetitionPlacement
  wins          Int                   @default(0)
  losses        Int                   @default(0)
  competedAt    DateTime
  note          String?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([userId, competedAt])
  @@index([gymId, competedAt])
}

model Injury {
  id         String         @id @default(cuid())
  userId     String
  gymId      String
  bodyPart   BodyPart
  severity   InjurySeverity
  status     InjuryStatus   @default(ACTIVE)
  startedAt  DateTime       @default(now())
  resolvedAt DateTime?
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([gymId, status])
}

// --- Auth.js v5 (@auth/prisma-adapter) required tables ----------------------
// Field names match the adapter spec exactly — do not rename.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
