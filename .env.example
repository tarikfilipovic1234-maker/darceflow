# --- Database (Neon serverless Postgres) -------------------------------------
# Pooled connection URL (use this in app runtime — appears as ...-pooler.region.aws.neon.tech)
DATABASE_URL=
# Direct (non-pooled) connection URL. Used by `prisma migrate dev`. Get it from
# Neon dashboard → Connection Details → uncheck "Pooled connection".
DIRECT_URL=

# --- Auth.js v5 --------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional in dev. Required on Vercel (set to your deployment URL).
AUTH_URL=

# --- Google OAuth (wired in Phase 2) -----------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Cron --------------------------------------------------------------------
# Shared secret that protects /api/cron/* endpoints. Vercel cron will send
# Authorization: Bearer <CRON_SECRET>. Generate with `openssl rand -base64 32`.
CRON_SECRET=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=darceflow
NEXT_PUBLIC_APP_URL=http://localhost:3000
